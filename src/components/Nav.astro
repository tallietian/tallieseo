---
interface Props {
  lang?: string;
}
const { lang = 'en' } = Astro.props;
const isEn = lang === 'en';
---

<nav class="nav">
  <div class="nav-inner">
    <a href={isEn ? '/' : '/zh/'} class="logo">
      <span class="logo-mark">◈</span>
      <span class="logo-text">TallieSEO</span>
    </a>
    <div class="nav-links">
      <a href={isEn ? '/#services' : '/zh/#services'}>{isEn ? 'Services' : '服务'}</a>
      <a href={isEn ? '/#process' : '/zh/#process'}>{isEn ? 'Process' : '流程'}</a>
      <a href={isEn ? '/#about' : '/zh/#about'}>{isEn ? 'About' : '关于'}</a>
      <a href={isEn ? '/#contact' : '/zh/#contact'} class="nav-cta">{isEn ? 'Get Started' : '立即咨询'}</a>
    </div>
    <div class="nav-right">
      <a href={isEn ? '/zh/' : '/'} class="lang-switch">
        {isEn ? '中文' : 'EN'}
      </a>
      <button class="menu-btn" aria-label="Menu">
        <span></span>
        <span></span>
      </button>
    </div>
  </div>
</nav>

<!-- Mobile menu -->
<div class="mobile-menu" id="mobileMenu">
  <div class="mobile-menu-inner">
    <a href={isEn ? '/#services' : '/zh/#services'}>{isEn ? 'Services' : '服务'}</a>
    <a href={isEn ? '/#process' : '/zh/#process'}>{isEn ? 'Process' : '流程'}</a>
    <a href={isEn ? '/#about' : '/zh/#about'}>{isEn ? 'About' : '关于'}</a>
    <a href={isEn ? '/#contact' : '/zh/#contact'}>{isEn ? 'Get Started' : '立即咨询'}</a>
  </div>
</div>

<script>
  const menuBtn = document.querySelector('.menu-btn');
  const mobileMenu = document.getElementById('mobileMenu');
  menuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('open');
    menuBtn.classList.toggle('active');
  });
  document.querySelectorAll('.mobile-menu a').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.remove('open');
      menuBtn?.classList.remove('active');
    });
  });
</script>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 1rem 2rem;
    background: rgba(10, 10, 10, 0.8);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--c-border);
  }
  .nav-inner {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 1.2rem;
    letter-spacing: -0.02em;
  }
  .logo-mark {
    color: var(--c-accent);
    font-size: 1.4rem;
  }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }
  .nav-links a {
    font-size: 0.9rem;
    color: var(--c-text-dim);
    transition: color 0.3s;
    letter-spacing: 0.02em;
  }
  .nav-links a:hover {
    color: var(--c-text);
  }
  .nav-cta {
    background: var(--c-accent) !important;
    color: var(--c-bg) !important;
    padding: 0.55rem 1.4rem;
    border-radius: 100px;
    font-weight: 600;
    font-size: 0.85rem !important;
    transition: transform 0.3s, box-shadow 0.3s !important;
  }
  .nav-cta:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 20px rgba(200, 255, 0, 0.3);
  }
  .nav-right {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .lang-switch {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    padding: 0.35rem 0.8rem;
    border: 1px solid var(--c-border);
    border-radius: 4px;
    color: var(--c-text-dim);
    transition: all 0.3s;
  }
  .lang-switch:hover {
    border-color: var(--c-accent);
    color: var(--c-accent);
  }
  .menu-btn {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }
  .menu-btn span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--c-text);
    transition: all 0.3s;
  }
  .menu-btn.active span:first-child {
    transform: rotate(45deg) translate(2.5px, 2.5px);
  }
  .menu-btn.active span:last-child {
    transform: rotate(-45deg) translate(2.5px, -2.5px);
  }
  .mobile-menu {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 99;
    background: rgba(10, 10, 10, 0.95);
    backdrop-filter: blur(20px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s;
  }
  .mobile-menu.open {
    opacity: 1;
    pointer-events: all;
  }
  .mobile-menu-inner {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    height: 100%;
    gap: 2rem;
  }
  .mobile-menu-inner a {
    font-size: 1.8rem;
    font-weight: 600;
    color: var(--c-text);
    transition: color 0.3s;
  }
  .mobile-menu-inner a:hover {
    color: var(--c-accent);
  }

  @media (max-width: 768px) {
    .nav-links { display: none; }
    .menu-btn { display: flex; }
    .mobile-menu { display: block; }
    .nav { padding: 1rem 1.2rem; }
  }
</style>
