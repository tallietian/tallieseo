---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="TallieSEO — 您的全球贸易增长伙伴" lang="zh">
  <Nav lang="zh" />

  <!-- HERO -->
  <section class="hero">
    <div class="hero-grid-bg"></div>
    <div class="hero-inner">
      <div class="hero-badge">
        <span class="badge-dot"></span>
        2026年Q2 正在接受新客户
      </div>
      <h1 class="hero-title">
        助力外贸企业
        <span class="hero-accent">称霸</span>
        全球市场。
      </h1>
      <p class="hero-sub">
        高转化网站、数据驱动SEO、精准广告投放 —— 
        您的品牌出海所需的一切，我们全部搞定。
      </p>
      <div class="hero-actions">
        <a href="#contact" class="btn-primary">预约免费咨询</a>
        <a href="#services" class="btn-ghost">查看服务 ↓</a>
      </div>
      <div class="hero-stats">
        <div class="stat">
          <span class="stat-num">150+</span>
          <span class="stat-label">服务客户</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-num">30+</span>
          <span class="stat-label">覆盖国家</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-num">3x</span>
          <span class="stat-label">平均流量增长</span>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="services" id="services">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-tag">// 服务</span>
        <h2 class="section-title">全链路增长方案，<br/>为全球卖家打造。</h2>
      </div>
      <div class="services-grid">
        <div class="service-card">
          <div class="service-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="2" y="3" width="20" height="14" rx="2" />
              <path d="M8 21h8M12 17v4" />
            </svg>
          </div>
          <h3>外贸网站建设</h3>
          <p>定制开发、SEO友好的外贸网站，专为将国际访客转化为优质询盘而设计。移动端优先，极速加载。</p>
          <ul class="service-tags">
            <li>响应式设计</li>
            <li>多语言支持</li>
            <li>速度优化</li>
          </ul>
        </div>
        <div class="service-card">
          <div class="service-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="11" cy="11" r="8" />
              <path d="M21 21l-4.35-4.35" />
              <path d="M11 8v6M8 11h6" />
            </svg>
          </div>
          <h3>SEO搜索优化</h3>
          <p>数据驱动的SEO策略，针对国际搜索引擎优化。提升您在Google等搜索引擎上的多市场自然排名。</p>
          <ul class="service-tags">
            <li>技术SEO</li>
            <li>内容策略</li>
            <li>外链建设</li>
          </ul>
        </div>
        <div class="service-card">
          <div class="service-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 20V10M18 20V4M6 20v-4" />
            </svg>
          </div>
          <h3>广告投放管理</h3>
          <p>Google Ads、Facebook、LinkedIn —— 精准定向广告，在正确的时间将您的产品展示给正确的买家。</p>
          <ul class="service-tags">
            <li>谷歌广告</li>
            <li>Meta广告</li>
            <li>LinkedIn广告</li>
          </ul>
        </div>
        <div class="service-card">
          <div class="service-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z" />
            </svg>
          </div>
          <h3>社媒推广营销</h3>
          <p>策略性社交媒体管理和内容营销，在全球平台上建立品牌权威并推动用户互动。</p>
          <ul class="service-tags">
            <li>内容营销</li>
            <li>社交媒体</li>
            <li>邮件营销</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="process" id="process">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-tag">// 流程</span>
        <h2 class="section-title">我们的工作方式。</h2>
      </div>
      <div class="process-steps">
        <div class="step">
          <div class="step-num">01</div>
          <h3>深度诊断</h3>
          <p>审计您当前的线上表现，分析竞争对手，深入了解您的目标市场和业务目标。</p>
        </div>
        <div class="step-line"></div>
        <div class="step">
          <div class="step-num">02</div>
          <h3>策略制定</h3>
          <p>量身定制增长路线图 —— 从网站架构到关键词策略再到广告创意，专属您的行业。</p>
        </div>
        <div class="step-line"></div>
        <div class="step">
          <div class="step-num">03</div>
          <h3>执行落地</h3>
          <p>团队全力构建、优化、上线。每周进度同步，报告透明可查。</p>
        </div>
        <div class="step-line"></div>
        <div class="step">
          <div class="step-num">04</div>
          <h3>持续增长</h3>
          <p>持续优化、A/B测试和规模化扩展。数据证明ROI，我们才算完成。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section class="about" id="about">
    <div class="section-inner">
      <div class="about-grid">
        <div class="about-content">
          <span class="section-tag">// 关于我们</span>
          <h2 class="section-title">为外贸企业而生，<br/>由行业老兵打造。</h2>
          <p>TallieSEO 由一支深耕跨境贸易多年的团队创立。我们深知外贸企业面临的独特挑战 —— 语言壁垒、文化差异、不同市场的搜索行为差异。</p>
          <p>我们将深厚的外贸行业认知与前沿数字营销技术相结合，交付泛泛之辈无法企及的增长成果。</p>
          <div class="about-highlights">
            <div class="highlight">
              <span class="highlight-icon">✦</span>
              <span>跨境贸易领域专家</span>
            </div>
            <div class="highlight">
              <span class="highlight-icon">✦</span>
              <span>多语种团队，覆盖10+语言</span>
            </div>
            <div class="highlight">
              <span class="highlight-icon">✦</span>
              <span>Google & Meta 认证合作伙伴</span>
            </div>
          </div>
        </div>
        <div class="about-visual">
          <div class="visual-card">
            <div class="visual-pattern"></div>
            <div class="visual-text">
              <span class="visual-big">6+</span>
              <span class="visual-label">年行业<br/>深耕经验</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section class="contact" id="contact">
    <div class="section-inner">
      <div class="contact-grid">
        <div class="contact-info">
          <span class="section-tag">// 开始合作</span>
          <h2 class="section-title">让我们一起，<br/>做大您的全球生意。</h2>
          <p class="contact-desc">准备好拓展新市场了吗？预约一次免费30分钟咨询，我们将分析您的现状并制定增长方案。</p>
          <div class="contact-details">
            <a href="mailto:hello@tallieseo.com" class="contact-link">
              <span class="contact-link-label">邮箱</span>
              <span>hello@tallieseo.com</span>
            </a>
          </div>
        </div>
        <form class="contact-form" action="https://formspree.io/f/your-form-id" method="POST">
          <div class="form-row">
            <div class="form-group">
              <label for="name">姓名</label>
              <input type="text" id="name" name="name" placeholder="您的姓名" required />
            </div>
            <div class="form-group">
              <label for="email">邮箱</label>
              <input type="email" id="email" name="email" placeholder="your@company.com" required />
            </div>
          </div>
          <div class="form-group">
            <label for="company">公司 & 网站</label>
            <input type="text" id="company" name="company" placeholder="公司名称及当前网站地址" />
          </div>
          <div class="form-group">
            <label for="service">感兴趣的服务</label>
            <select id="service" name="service">
              <option value="">请选择服务</option>
              <option value="website">外贸网站建设</option>
              <option value="seo">SEO搜索优化</option>
              <option value="ads">广告投放管理</option>
              <option value="social">社媒推广营销</option>
              <option value="full">全套服务</option>
            </select>
          </div>
          <div class="form-group">
            <label for="message">请描述您的目标</label>
            <textarea id="message" name="message" rows="4" placeholder="目标市场、当前挑战、增长目标..."></textarea>
          </div>
          <button type="submit" class="btn-primary btn-full">提交咨询 →</button>
        </form>
      </div>
    </div>
  </section>

  <Footer lang="zh" />
</Layout>

<style>
  /* ===== HERO ===== */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 8rem 2rem 4rem;
    overflow: hidden;
  }
  .hero-grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(200,255,0,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(200,255,0,0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse at 50% 50%, black 20%, transparent 70%);
  }
  .hero-inner {
    max-width: 1400px;
    margin: 0 auto;
    width: 100%;
    position: relative;
  }
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--c-accent);
    border: 1px solid var(--c-border);
    padding: 0.4rem 1rem;
    border-radius: 100px;
    margin-bottom: 2rem;
    animation: fadeInUp 0.8s ease;
  }
  .badge-dot {
    width: 6px;
    height: 6px;
    background: var(--c-accent);
    border-radius: 50%;
    animation: pulse 2s infinite;
  }
  .hero-title {
    font-size: clamp(2.8rem, 7vw, 5.5rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.03em;
    max-width: 900px;
    margin-bottom: 1.5rem;
    animation: fadeInUp 0.8s ease 0.1s both;
  }
  .hero-accent {
    color: var(--c-accent);
    font-style: italic;
  }
  .hero-sub {
    font-size: 1.15rem;
    color: var(--c-text-dim);
    max-width: 580px;
    line-height: 1.8;
    margin-bottom: 2.5rem;
    animation: fadeInUp 0.8s ease 0.2s both;
  }
  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 4rem;
    animation: fadeInUp 0.8s ease 0.3s both;
  }
  .btn-primary {
    display: inline-flex;
    align-items: center;
    background: var(--c-accent);
    color: var(--c-bg);
    padding: 0.8rem 2rem;
    border-radius: 100px;
    font-weight: 600;
    font-size: 0.95rem;
    border: none;
    cursor: pointer;
    transition: transform 0.3s, box-shadow 0.3s;
    font-family: var(--font-body);
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 30px rgba(200, 255, 0, 0.25);
  }
  .btn-ghost {
    display: inline-flex;
    align-items: center;
    padding: 0.8rem 2rem;
    border: 1px solid var(--c-border);
    border-radius: 100px;
    font-size: 0.95rem;
    color: var(--c-text-dim);
    transition: all 0.3s;
  }
  .btn-ghost:hover {
    border-color: var(--c-text-dim);
    color: var(--c-text);
  }
  .btn-full { width: 100%; justify-content: center; }
  .hero-stats {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    animation: fadeInUp 0.8s ease 0.4s both;
  }
  .stat-num {
    display: block;
    font-family: var(--font-mono);
    font-size: 2rem;
    font-weight: 700;
    color: var(--c-accent);
  }
  .stat-label {
    font-size: 0.8rem;
    color: var(--c-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .stat-divider {
    width: 1px;
    height: 40px;
    background: var(--c-border);
  }

  /* ===== SECTIONS SHARED ===== */
  .section-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 6rem 2rem;
  }
  .section-header { margin-bottom: 4rem; }
  .section-tag {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--c-accent);
    letter-spacing: 0.1em;
    display: block;
    margin-bottom: 1rem;
  }
  .section-title {
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  /* ===== SERVICES ===== */
  .services { border-top: 1px solid var(--c-border); }
  .services-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }
  .service-card {
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: 12px;
    padding: 2.5rem;
    transition: border-color 0.4s, transform 0.3s;
  }
  .service-card:hover {
    border-color: var(--c-accent);
    transform: translateY(-4px);
  }
  .service-icon {
    width: 56px;
    height: 56px;
    border-radius: 12px;
    background: var(--c-surface-2);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--c-accent);
    margin-bottom: 1.5rem;
  }
  .service-card h3 {
    font-size: 1.3rem;
    margin-bottom: 0.8rem;
  }
  .service-card p {
    color: var(--c-text-dim);
    font-size: 0.95rem;
    line-height: 1.8;
    margin-bottom: 1.5rem;
  }
  .service-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
  }
  .service-tags li {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    padding: 0.3rem 0.7rem;
    border: 1px solid var(--c-border);
    border-radius: 100px;
    color: var(--c-text-muted);
  }

  /* ===== PROCESS ===== */
  .process {
    border-top: 1px solid var(--c-border);
    background: var(--c-surface);
  }
  .process-steps {
    display: flex;
    align-items: flex-start;
  }
  .step { flex: 1; padding: 2rem; }
  .step-num {
    font-family: var(--font-mono);
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--c-accent);
    margin-bottom: 1rem;
    line-height: 1;
  }
  .step h3 { font-size: 1.2rem; margin-bottom: 0.8rem; }
  .step p { color: var(--c-text-dim); font-size: 0.9rem; line-height: 1.8; }
  .step-line {
    width: 1px;
    min-height: 180px;
    background: linear-gradient(to bottom, transparent, var(--c-accent), transparent);
    align-self: stretch;
    margin-top: 2rem;
  }

  /* ===== ABOUT ===== */
  .about { border-top: 1px solid var(--c-border); }
  .about-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 4rem;
    align-items: center;
  }
  .about-content p {
    color: var(--c-text-dim);
    font-size: 1rem;
    line-height: 1.9;
    margin-top: 1.5rem;
  }
  .about-highlights {
    margin-top: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }
  .highlight {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    font-size: 0.95rem;
  }
  .highlight-icon { color: var(--c-accent); font-size: 0.8rem; }
  .about-visual { display: flex; justify-content: center; }
  .visual-card {
    width: 280px;
    height: 340px;
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: 16px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .visual-pattern {
    flex: 1;
    background-image: repeating-linear-gradient(45deg, var(--c-border) 0, var(--c-border) 1px, transparent 1px, transparent 12px);
  }
  .visual-text {
    padding: 2rem;
    display: flex;
    align-items: flex-end;
    gap: 1rem;
  }
  .visual-big {
    font-family: var(--font-mono);
    font-size: 4rem;
    font-weight: 700;
    color: var(--c-accent);
    line-height: 1;
  }
  .visual-label {
    font-size: 0.85rem;
    color: var(--c-text-dim);
    line-height: 1.5;
    padding-bottom: 0.3rem;
  }

  /* ===== CONTACT ===== */
  .contact {
    border-top: 1px solid var(--c-border);
    background: var(--c-surface);
  }
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
  }
  .contact-desc {
    color: var(--c-text-dim);
    font-size: 1rem;
    line-height: 1.9;
    margin-top: 1.5rem;
  }
  .contact-details { margin-top: 2.5rem; }
  .contact-link {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 1rem 0;
    border-top: 1px solid var(--c-border);
    transition: color 0.3s;
  }
  .contact-link:hover { color: var(--c-accent); }
  .contact-link-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--c-text-muted);
  }
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.2rem;
  }
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .form-group label {
    font-size: 0.8rem;
    color: var(--c-text-dim);
    font-family: var(--font-mono);
  }
  .form-group input,
  .form-group select,
  .form-group textarea {
    background: var(--c-bg);
    border: 1px solid var(--c-border);
    border-radius: 8px;
    padding: 0.8rem 1rem;
    color: var(--c-text);
    font-family: var(--font-body);
    font-size: 0.95rem;
    transition: border-color 0.3s;
    outline: none;
  }
  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    border-color: var(--c-accent);
  }
  .form-group select { appearance: none; cursor: pointer; }
  .form-group textarea { resize: vertical; min-height: 100px; }

  /* ===== ANIMATIONS ===== */
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 1024px) {
    .services-grid { grid-template-columns: 1fr; }
    .process-steps { flex-direction: column; }
    .step-line {
      width: 100%;
      min-height: 0;
      height: 1px;
      background: linear-gradient(to right, transparent, var(--c-accent), transparent);
      margin-top: 0;
    }
    .about-grid { grid-template-columns: 1fr; }
    .contact-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 768px) {
    .hero { padding: 7rem 1.2rem 3rem; }
    .hero-stats { flex-wrap: wrap; gap: 1.5rem; }
    .stat-divider { display: none; }
    .section-inner { padding: 4rem 1.2rem; }
    .form-row { grid-template-columns: 1fr; }
    .service-card { padding: 1.8rem; }
  }
</style>
