---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Layout title="博客 — TallieSEO" lang="zh">
  <Nav lang="zh" />

  <section class="blog-list">
    <div class="blog-inner">
      <div class="blog-header">
        <span class="section-tag">// BLOG</span>
        <h1 class="section-title">洞察与分享</h1>
        <p class="blog-desc">外贸推广、SEO优化、广告投放领域的最新见解和实战经验。</p>
      </div>
      <div class="posts-grid">
        {posts.map((post) => (
          <a href={`/blog/${post.id}/`} class="post-card">
            <div class="post-card-meta">
              <span class="post-card-date">
                {post.data.date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
              </span>
              <div class="post-card-tags">
                {post.data.tags.slice(0, 2).map((tag: string) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            </div>
            <h2 class="post-card-title">{post.data.title}</h2>
            <p class="post-card-desc">{post.data.description}</p>
            <span class="post-card-link">阅读全文 →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Footer lang="zh" />
</Layout>

<style>
  .blog-list {
    padding-top: 6rem;
  }
  .blog-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 2rem;
  }
  .blog-header {
    margin-bottom: 4rem;
  }
  .section-tag {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--c-accent);
    letter-spacing: 0.1em;
    display: block;
    margin-bottom: 1rem;
  }
  .section-title {
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin-bottom: 1rem;
  }
  .blog-desc {
    color: var(--c-text-dim);
    font-size: 1.05rem;
    max-width: 500px;
  }
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }
  .post-card {
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: 12px;
    padding: 2.5rem;
    transition: border-color 0.4s, transform 0.3s;
    display: flex;
    flex-direction: column;
  }
  .post-card:hover {
    border-color: var(--c-accent);
    transform: translateY(-4px);
  }
  .post-card-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.2rem;
  }
  .post-card-date {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--c-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .post-card-tags {
    display: flex;
    gap: 0.4rem;
  }
  .tag {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    padding: 0.2rem 0.6rem;
    border: 1px solid var(--c-border);
    border-radius: 100px;
    color: var(--c-accent);
  }
  .post-card-title {
    font-size: 1.3rem;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 0.8rem;
    letter-spacing: -0.01em;
  }
  .post-card-desc {
    color: var(--c-text-dim);
    font-size: 0.9rem;
    line-height: 1.7;
    flex: 1;
    margin-bottom: 1.5rem;
  }
  .post-card-link {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--c-accent);
    transition: opacity 0.3s;
  }
  .post-card:hover .post-card-link {
    opacity: 0.8;
  }

  @media (max-width: 768px) {
    .posts-grid { grid-template-columns: 1fr; }
    .blog-inner { padding: 1.2rem; }
    .post-card { padding: 1.8rem; }
  }
</style>
